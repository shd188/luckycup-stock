.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #f5f7fb;
}

.header {
  padding: 32rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 600;
  color: #111827;
}

.subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.store-list {
  flex: 1;
  padding: 0 32rpx 32rpx;
  box-sizing: border-box;
}

.store-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx;
  margin-bottom: 24rpx;
  border-radius: 20rpx;
  background-color: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.store-main {
  display: flex;
  flex-direction: column;
}

.store-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #111827;
}

.store-code {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #6b7280;
}

.store-enter {
  font-size: 24rpx;
}

.empty {
  flex: 1;
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: #6b7280;
}

.empty-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #111827;
}

.empty-subtitle {
  margin-top: 8rpx;
  font-size: 24rpx;
}

.footer {
  padding: 24rpx 32rpx;
  box-shadow: 0 -4rpx 12rpx rgba(15, 23, 42, 0.04);
  background-color: #ffffff;
}

.primary-btn {
  width: 100%;
  border-radius: 999rpx;
}


