page {
  background-color: #F0F2F6;
}

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #F0F2F6;
}

/* ── Hero ── */
.hero {
  background: linear-gradient(150deg, #141A2B 0%, #1E2D50 100%);
  padding: 56rpx 40rpx 52rpx;
}

.hero-top {
  display: flex;
  align-items: baseline;
  margin-bottom: 16rpx;
}

.brand-cn {
  font-size: 56rpx;
  font-weight: 700;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.brand-en {
  margin-left: 20rpx;
  font-size: 22rpx;
  font-weight: 400;
  color: #C8974F;
  letter-spacing: 4rpx;
}

.hero-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.45);
  letter-spacing: 1rpx;
}

/* ── Section Header ── */
.section-bar {
  display: flex;
  align-items: center;
  padding: 36rpx 40rpx 20rpx;
}

.section-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background-color: #3B6FE8;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.section-title {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.section-badge {
  background-color: #E5E7EB;
  border-radius: 999rpx;
  padding: 4rpx 18rpx;
}

.section-badge-text {
  font-size: 22rpx;
  color: #6B7280;
}

/* ── Store Cards ── */
.store-list {
  padding: 0 24rpx;
}

.store-card {
  display: flex;
  align-items: stretch;
  background-color: #FFFFFF;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
}

.store-accent {
  width: 8rpx;
  background-color: #3B6FE8;
  flex-shrink: 0;
}

.store-body {
  flex: 1;
  padding: 32rpx 24rpx;
}

.store-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 10rpx;
}

.store-code {
  font-size: 24rpx;
  color: #9CA3AF;
}

.store-chevron {
  display: flex;
  align-items: center;
  padding-right: 28rpx;
}

.chevron-icon {
  font-size: 44rpx;
  color: #D1D5DB;
  line-height: 1;
  font-weight: 300;
}

/* ── Empty State ── */
.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-icon-wrap {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  background-color: #E5E7EB;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 32rpx;
}

.empty-icon {
  font-size: 68rpx;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #9CA3AF;
  text-align: center;
  line-height: 1.7;
}

/* ── Footer ── */
.footer {
  margin-top: auto;
  padding: 24rpx 40rpx 52rpx;
  background-color: #FFFFFF;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.07);
}

.add-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 999rpx;
  background-color: #141A2B;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(20, 26, 43, 0.25);
}

.add-btn::after {
  border: none;
}
