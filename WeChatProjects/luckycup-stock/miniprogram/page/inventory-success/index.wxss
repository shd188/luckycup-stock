page {
  background-color: #F0F2F6;
}

.page {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background-color: #F0F2F6;
}

/* ── Content ── */
.content {
  flex: 1;
  padding: 60rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* ── Success Icon ── */
.success-icon-wrap {
  margin-bottom: 40rpx;
}

.success-ring {
  width: 140rpx;
  height: 140rpx;
  border-radius: 70rpx;
  background: linear-gradient(135deg, #141A2B 0%, #3B6FE8 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 12rpx 40rpx rgba(59, 111, 232, 0.3);
}

.success-check {
  font-size: 68rpx;
  color: #FFFFFF;
  font-weight: 300;
  line-height: 1;
}

/* ── Title ── */
.success-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.success-sub {
  font-size: 26rpx;
  color: #9CA3AF;
  margin-bottom: 48rpx;
}

/* ── Info Card ── */
.info-card {
  width: 100%;
  background-color: #FFFFFF;
  border-radius: 24rpx;
  padding: 8rpx 0;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.06);
  margin-bottom: 32rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 36rpx;
}

.info-label {
  font-size: 26rpx;
  color: #9CA3AF;
}

.info-value {
  font-size: 26rpx;
  font-weight: 500;
  color: #111827;
  flex: 1;
  text-align: right;
}

.divider {
  height: 1rpx;
  background-color: #F3F4F6;
  margin: 0 36rpx;
}

/* ── Share Tip ── */
.share-tip {
  display: flex;
  align-items: flex-start;
  background-color: #FFF8EF;
  border: 1rpx solid rgba(200, 151, 79, 0.3);
  border-radius: 16rpx;
  padding: 24rpx 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.share-tip-icon {
  font-size: 28rpx;
  margin-right: 14rpx;
  flex-shrink: 0;
}

.share-tip-text {
  font-size: 24rpx;
  color: #92650A;
  line-height: 1.7;
}

/* ── Footer ── */
.footer {
  padding: 24rpx 40rpx 52rpx;
  background-color: #FFFFFF;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.07);
}

.back-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 999rpx;
  background-color: #141A2B;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(20, 26, 43, 0.25);
}

.back-btn::after {
  border: none;
}

/* ── Share Guide Overlay ── */
.guide-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.78);
  z-index: 999;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

/* 右上角气泡 */
.guide-bubble-area {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  padding-top: 0;
  padding-right: 20rpx;
}

/* 尾巴在气泡上方，指向导航栏 ··· */
.guide-bubble-tail {
  width: 0;
  height: 0;
  border-left: 18rpx solid transparent;
  border-right: 18rpx solid transparent;
  border-bottom: 22rpx solid #FFFFFF;
  margin-right: 100rpx;
}

.guide-bubble {
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 14rpx 28rpx;
}

.guide-bubble-text {
  font-size: 26rpx;
  font-weight: 600;
  color: #141A2B;
}

/* 中部主体 */
.guide-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 64rpx 160rpx;
}

.guide-icon-wrap {
  width: 112rpx;
  height: 112rpx;
  border-radius: 56rpx;
  background-color: rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 36rpx;
}

.guide-icon {
  font-size: 52rpx;
  line-height: 1;
}

.guide-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #FFFFFF;
  margin-bottom: 20rpx;
  letter-spacing: 2rpx;
}

.guide-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  text-align: center;
  line-height: 1.8;
  margin-bottom: 64rpx;
}

.guide-dismiss-btn {
  background-color: #FFFFFF;
  border-radius: 999rpx;
  padding: 22rpx 80rpx;
}

.guide-dismiss-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #141A2B;
}
