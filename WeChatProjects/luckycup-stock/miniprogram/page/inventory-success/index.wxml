<view class="page">
  <!-- Success Content -->
  <view class="content">
    <!-- Icon -->
    <view class="success-icon-wrap">
      <view class="success-ring">
        <text class="success-check">✓</text>
      </view>
    </view>

    <!-- Title -->
    <text class="success-title">盘点已提交</text>
    <text class="success-sub">本次盘点结果已锁定，不可修改</text>

    <!-- Info Card -->
    <view class="info-card">
      <view class="info-row">
        <text class="info-label">门店</text>
        <text class="info-value">{{store.store_name}}</text>
      </view>
      <view class="divider"></view>
      <view class="info-row">
        <text class="info-label">门店编号</text>
        <text class="info-value">{{store.store_code}}</text>
      </view>
      <view class="divider"></view>
      <view class="info-row">
        <text class="info-label">完成时间</text>
        <text class="info-value">{{finishedAt}}</text>
      </view>
      <view class="divider"></view>
      <view class="info-row">
        <text class="info-label">盘点人</text>
        <text class="info-value">{{userNickname}}</text>
      </view>
    </view>

    <!-- Share Tip -->
    <view class="share-tip">
      <text class="share-tip-icon">💡</text>
      <text class="share-tip-text">如需分享盘点结果，点击右上角「···」并选择"转发给朋友"</text>
    </view>
  </view>

  <!-- Footer -->
  <view class="footer">
    <button class="back-btn" bindtap="onBack">返回门店列表</button>
  </view>
</view>
