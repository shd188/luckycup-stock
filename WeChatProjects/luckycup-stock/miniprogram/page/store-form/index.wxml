<view class="page">
  <!-- Header -->
  <view class="page-header">
    <text class="page-title">新增门店</text>
    <text class="page-sub">填写门店信息以加入盘点系统</text>
  </view>

  <!-- Form Card -->
  <view class="form-card">
    <view class="field">
      <text class="field-label">门店编号</text>
      <input
        class="field-input"
        placeholder="请输入门店编号"
        placeholder-class="field-placeholder"
        type="number"
        maxlength="8"
        value="{{storeCode}}"
        bindinput="onInputStoreCode"
      />
      <view class="field-line"></view>
    </view>

    <view class="field">
      <text class="field-label">门店名称</text>
      <input
        class="field-input"
        placeholder="请输入门店名称"
        placeholder-class="field-placeholder"
        value="{{storeName}}"
        bindinput="onInputStoreName"
      />
      <view class="field-line"></view>
    </view>
  </view>

  <!-- Tip -->
  <view class="form-tip">
    <text class="tip-text">提示：门店编号用于唯一识别门店，请确认填写正确</text>
  </view>

  <!-- Footer -->
  <view class="footer">
    <button class="save-btn" bindtap="onSubmit" disabled="{{submitting}}">{{submitting ? '保存中…' : '保 存'}}</button>
  </view>
</view>

