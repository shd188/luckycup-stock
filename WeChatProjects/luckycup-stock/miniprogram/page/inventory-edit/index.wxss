page {
  background-color: #F0F2F6;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background-color: #F0F2F6;
}

/* ── Store Header ── */
.store-header {
  display: flex;
  align-items: center;
  padding: 28rpx 40rpx;
  background: linear-gradient(135deg, #141A2B 0%, #1E2D50 100%);
}

.store-header-main {
  flex: 1;
}

.store-header-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.store-header-code {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
}

.store-header-badge {
  background-color: rgba(200, 151, 79, 0.2);
  border: 1rpx solid rgba(200, 151, 79, 0.5);
  border-radius: 999rpx;
  padding: 6rpx 20rpx;
}

.store-header-badge-text {
  font-size: 22rpx;
  color: #C8974F;
}

/* ── Tip Bar ── */
.tip-bar {
  padding: 16rpx 40rpx;
  background-color: #EEF2FF;
  border-left: 6rpx solid #C8974F;
  margin: 16rpx 24rpx;
  border-radius: 0 12rpx 12rpx 0;
}

.tip-text {
  font-size: 22rpx;
  color: #C8974F;
  line-height: 1.6;
}

/* ── Material Scroll ── */
.material-scroll {
  flex: 1;
  height: 0;
}

/* ── Category Block ── */
.category-block {
  padding: 0 24rpx;
}

/* ── Category Header (Sticky) ── */
.cat-header {
  display: flex;
  align-items: center;
  padding: 20rpx 0 14rpx;
}

.sticky-cat {
  position: sticky;
  top: 0;
  z-index: 10;
  background-color: #F0F2F6;
  margin-left: -24rpx;
  margin-right: -24rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
}

.cat-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  flex-shrink: 0;
  margin-right: 14rpx;
}

.cat-dot-0 { background-color: #3B6FE8; }
.cat-dot-1 { background-color: #2DB07D; }
.cat-dot-2 { background-color: #C8974F; }

.cat-name {
  flex: 1;
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.cat-count-badge {
  background-color: #E5E7EB;
  border-radius: 999rpx;
  padding: 4rpx 16rpx;
}

.cat-count-text {
  font-size: 20rpx;
  color: #6B7280;
}

/* ── Material Card ── */
.material-card {
  display: flex;
  align-items: center;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0, 0, 0, 0.05);
}

.material-accent {
  width: 6rpx;
  align-self: stretch;
  flex-shrink: 0;
}

.material-accent-0 { background-color: #3B6FE8; }
.material-accent-1 { background-color: #2DB07D; }
.material-accent-2 { background-color: #C8974F; }

.material-info {
  flex: 1;
  padding: 24rpx 20rpx;
}

.material-name {
  display: block;
  font-size: 28rpx;
  font-weight: 500;
  color: #111827;
  margin-bottom: 6rpx;
}

.material-unit {
  font-size: 22rpx;
  color: #9CA3AF;
}

.material-input-wrap {
  padding: 0 20rpx;
}

.material-input {
  width: 140rpx;
  height: 64rpx;
  line-height: 64rpx;
  text-align: center;
  border-radius: 12rpx;
  background-color: #F3F4F6;
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  border: 2rpx solid transparent;
}

.material-placeholder {
  color: #D1D5DB;
  font-size: 24rpx;
  font-weight: 400;
}

/* ── Footer ── */
.footer {
  padding: 20rpx 40rpx 48rpx;
  background-color: #FFFFFF;
  box-shadow: 0 -2rpx 20rpx rgba(0, 0, 0, 0.07);
}

.footer-tip {
  font-size: 22rpx;
  color: #9CA3AF;
  margin-bottom: 16rpx;
  text-align: center;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  border-radius: 999rpx;
  background-color: #141A2B;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(20, 26, 43, 0.25);
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  background-color: #9CA3AF;
  box-shadow: none;
}
