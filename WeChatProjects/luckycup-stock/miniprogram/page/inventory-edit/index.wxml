<view class="page">
  <!-- Store Header -->
  <view class="store-header">
    <view class="store-header-main">
      <text class="store-header-name">{{store.store_name}}</text>
      <text class="store-header-code">编号 · {{store.store_code}}</text>
    </view>
    <view class="store-header-badge">
      <text class="store-header-badge-text">盘点中</text>
    </view>
  </view>

  <!-- Tip -->
  <view class="tip-bar">
    <text class="tip-text">请填写全部物料库存数量，可填 0，不可留空</text>
  </view>

  <!-- Material List (scrollable) -->
  <scroll-view scroll-y class="material-scroll" enable-back-to-top>
    <block wx:for="{{categories}}" wx:for-item="category" wx:key="category_id" wx:for-index="cIdx">
      <view class="category-block">
        <!-- Sticky Category Title -->
        <view class="cat-header sticky-cat">
          <view class="cat-dot cat-dot-{{cIdx % 3}}"></view>
          <text class="cat-name">{{category.name}}</text>
          <view class="cat-count-badge">
            <text class="cat-count-text">{{category.materials.length}} 项</text>
          </view>
        </view>

        <!-- Material Items -->
        <block wx:for="{{category.materials}}" wx:for-item="material" wx:key="material_id">
          <view class="material-card">
            <view class="material-accent material-accent-{{cIdx % 3}}"></view>
            <view class="material-info">
              <text class="material-name">{{material.name}}</text>
              <text class="material-unit">{{material.unit}}</text>
            </view>
            <view class="material-input-wrap">
              <input
                class="material-input"
                type="digit"
                placeholder="数量"
                placeholder-class="material-placeholder"
                value="{{material.quantity}}"
                data-category-id="{{category.category_id}}"
                data-material-id="{{material.material_id}}"
                bindinput="onInputQuantity"
              />
            </view>
          </view>
        </block>
      </view>
    </block>
    <!-- Bottom padding -->
    <view style="height: 32rpx;"></view>
  </scroll-view>

  <!-- Footer -->
  <view class="footer">
    <view class="footer-tip">* 所有物料均需填写，可填 0</view>
    <button class="submit-btn" bindtap="onSubmit" disabled="{{submitting}}">{{submitting ? '提交中…' : '提交盘点'}}</button>
  </view>
</view>
